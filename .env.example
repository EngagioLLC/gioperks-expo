EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Optional: FastAPI base URL (no trailing slash)
# EXPO_PUBLIC_API_URL=https://engagio.biz/rewards

# Optional: fixed OAuth redirect origin when testing from other devices (Tailscale MagicDNS, etc.)
# EXPO_PUBLIC_AUTH_REDIRECT_ORIGIN=http://your-machine.your-tailnet.ts.net:8081
#
# Supabase Dashboard → Authentication → URL configuration:
# 1. Site URL: set to your primary dev URL (NOT localhost:3000 unless you use that port).
# 2. Redirect URLs — add every origin you use, for example:
#    - http://YOUR_TAILSCALE_HOST:8081/**
#    - gioperksexpo://auth/callback
#    - exp://YOUR_DEV_MACHINE_IP:8081/--/auth/callback   (Expo Go; check Metro console [auth] log)
# If redirectTo is missing or not allowlisted, Supabase sends users to Site URL instead.
